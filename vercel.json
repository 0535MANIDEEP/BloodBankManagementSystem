{
  "version": 2,
  "installCommand": "npm install --legacy-peer-deps && cd client && npm install --legacy-peer-deps",
  "buildCommand": "cd client && npx vite build",
  "outputDirectory": "client/dist",
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/index.js"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
